raw-git-url.md
# ========================
# Rust / Cargo Build Artifacts
# ========================

# The primary build output directory for Cargo projects.
/target/

# Remove Cargo.lock from gitignore ONLY if you are building a library.
# For applications (binaries), you SHOULD commit this file for reproducibility.
Cargo.lock

# Backup files generated by rustfmt.
**/*.rs.bk

# Debugging files generated on MSVC Windows builds.
*.pdb

# ========================
# IDE and Editor Files
# ========================

# RustRover / IntelliJ
.idea/
*.iml

# VS Code
.vscode/

# Vim
*.swp
*.swo
.vim/

# Helix
.helix/

# Emacs
*~
\#*\#
.dir-locals.el

# ========================
# Operating System Files
# ========================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
desktop.ini

# Linux
.directory

# ========================
# Environment & Local Configuration
# ========================

# User-specific Cargo configuration (contains local paths).
# Keep the directory itself to prevent accidental commits, but negate an
# example file if you want to provide a template.
.cargo/
!.cargo/config.toml.template

# Environment files
.env
.envrc
.direnv/

# ========================
# Debug & Profiling
# ========================

# Rust compiler ICE (Internal Compiler Error) reports.
rustc-ice-*.txt

# Profiling data.
*.prof
*.profraw

# ========================
# Documentation
# ========================

# Generated documentation.
/target/doc/

# ========================
# Miscellaneous
# ========================

# Python cache (sometimes present in build scripts)
__pycache__/

# Node modules (for wasm or GUI tests)
node_modules/
